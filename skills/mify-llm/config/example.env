# Mify LLM API 配置示例

# API 密钥（必需）
export MIFY_API_KEY="your-api-key-here"

# API 基础 URL（可选，默认：http://model.mify.ai.srv/v1）
export MIFY_BASE_URL="http://model.mify.ai.srv/v1"

# 默认模型（可选）
export MIFY_MODEL="mify-chat-v1"

# 最大生成 token 数（可选，默认：2048）
export MIFY_MAX_TOKENS="2048"

# 温度参数（可选，默认：0.7，范围 0-2）
export MIFY_TEMPERATURE="0.7"
